---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import AccountDashboard from '../../components/account/AccountDashboard.vue';
---

<BaseLayout title="My Account" description="Manage your Cook Book Bake account">
  <div class="container mx-auto px-4 py-12">
    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold text-accent-teal mb-2">My Account</h1>
      <p class="text-xl text-text-secondary">Manage your profile and orders</p>
    </div>

    <!-- Account Dashboard -->
    <AccountDashboard client:load />
  </div>
</BaseLayout>
